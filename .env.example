# ──────────────────────────────────────────────────────────────────
# 거지밥 환경변수 설정 예시
# 이 파일을 복사해 .env 파일을 만들고 실제 API 키를 입력하세요.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────

# 농림수산식품교육문화정보원 레시피 API
# 엔드포인트: http://211.237.50.150:7080/openapi/{KEY}/json/Grid_20150827000000000226_1/{start}/{end}
# 개발 서버: Vite 프록시(/api-proxy/recipe) 경유로 CORS 우회
VITE_RECIPE_API_KEY=여기에_발급받은_인증키_입력

# 식품의약품안전처 식품영양성분 데이터베이스 API
# 엔드포인트: https://apis.data.go.kr/1471000/FoodNtrCpntDbInfo02/getFoodNtrCpntDbInq02
VITE_NUTRITION_API_KEY=여기에_발급받은_인증키_입력

# 쿠팡 파트너스 (제휴 수수료 연동)
# 1. https://partners.coupang.com 에서 파트너 계정 신청
# 2. 승인 후 대시보드 > 내 정보 > 파트너스 ID 확인
# 3. 아래에 입력하면 재료 구매 링크에 수수료 추적이 자동 적용됨
# 미설정 시: 일반 검색 링크 (로켓배송 우선) 사용
VITE_COUPANG_PARTNER_ID=

# ── 식단 AI 에이전트 (서버사이드 전용) ───────────────────────────────
# Vercel 서버리스 함수(/api/meal-suggest)에서 Claude가 예산·난이도에 맞는
# 최적 식단을 추천한다. 미설정 시 기존 랜덤 생성으로 자동 폴백.
#
# 발급: https://console.anthropic.com → API Keys
# Vercel 배포 환경변수 설정: Vercel 대시보드 > Settings > Environment Variables
# ※ VITE_ 접두사 없음 — 브라우저에 노출되지 않음 (서버 전용)
ANTHROPIC_API_KEY=
